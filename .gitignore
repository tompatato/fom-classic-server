# --- Copyrighted game material — NEVER commit ---
# Binaries/assets live OUTSIDE the tree; these are the in-repo staging dirs.
# NOTE: no blanket *.dll/*.exe/*.lto globs on purpose — the RE work product under
# disassembly/symbols/ lives in directories NAMED after modules (e.g.
# symbols/<module>.dll/…), and such globs would silently ignore that data.
/client/
/binaries/

# --- Host-specific RE config (paths differ per machine) ---
tools/re/ghidra.local.json

# --- Ghidra project + scratch (commit the exported JSON, never the project) ---
*.gpr
*.rep/
*.gzf
*.lock
*.lock~
local.just

# --- Python ---
__pycache__/
*.pyc
.venv/

# --- Build output (once servers exist) ---
out/
build/

# --- Obsidian per-user workspace state (keep the notes, drop the UI state) ---
knowledge-base/**/.obsidian/workspace*
knowledge-base/**/.obsidian/cache

# --- Editor / OS ---
.idea/
.vscode/
.DS_Store

# --- .NET build output ---
bin/
obj/
*.user
